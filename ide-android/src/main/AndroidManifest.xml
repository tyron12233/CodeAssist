<?xml version="1.0" encoding="utf-8"?>
<!-- The package/namespace comes from android.namespace in build.gradle.kts (AGP 9.x). -->
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Maven dependency resolution downloads artifacts from Maven Central (the Dependencies screen). -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- The android "Run" builds a debug APK and installs it via PackageInstaller; the OS shows its own
         install-confirmation. The user must also grant "install unknown apps" to CodeAssist (we deep-link
         to that Settings screen when it isn't granted yet). -->
    <uses-permission android:name="android.permission.REQUEST_INSTALL_PACKAGES" />

    <!-- The bundled aapt2/zipalign (lib*.so) must be EXTRACTED into nativeLibraryDir at install so they can
         be exec'd (ART forbids executing binaries from anywhere else). That extraction is driven by
         packaging.jniLibs.useLegacyPackaging=true in build.gradle.kts (which sets extractNativeLibs on the
         merged manifest); declaring it here too is redundant, so AGP owns it. -->
    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@android:style/Theme.Material.NoActionBar">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:windowSoftInputMode="adjustResize"
            android:configChanges="orientation|screenSize|screenLayout|keyboardHidden|keyboard|navigation|uiMode|density|fontScale|smallestScreenSize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <!-- "Open with CodeAssist": another app hands us a single file to import into the project. -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="text/*" />
                <data android:mimeType="application/json" />
                <data android:mimeType="application/xml" />
            </intent-filter>
            <!-- "Share to CodeAssist": receive a shared file from another app. -->
            <intent-filter>
                <action android:name="android.intent.action.SEND" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="text/*" />
                <data android:mimeType="application/json" />
                <data android:mimeType="application/xml" />
            </intent-filter>
        </activity>

        <!-- Exposes app-private project files (filesDir/codeassist) to other apps as content:// URIs
             for Share / "Open with", without FileUriExposedException. -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>
    </application>

</manifest>
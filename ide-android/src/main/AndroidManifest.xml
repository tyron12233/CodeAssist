<?xml version="1.0" encoding="utf-8"?><!-- The package/namespace comes from android.namespace in build.gradle.kts (AGP 9.x). -->
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Maven dependency resolution downloads artifacts from Maven Central (the Dependencies screen). -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- Package visibility (Android 11+/API 30): the android "Run" installs the user's APK and then
         launches it. getLaunchIntentForPackage / queryIntentActivities are filtered unless the target is
         visible; the installer already sees what it installs, but declaring the MAIN/LAUNCHER query makes
         that resolution robust (and is the standard fix for getLaunchIntentForPackage returning null). -->
    <queries>
        <intent>
            <action android:name="android.intent.action.MAIN" />
            <category android:name="android.intent.category.LAUNCHER" />
        </intent>
    </queries>

    <!-- The android "Run" builds a debug APK and installs it via PackageInstaller; the OS shows its own
         install-confirmation. The user must also grant "install unknown apps" to CodeAssist (we deep-link
         to that Settings screen when it isn't granted yet). -->
    <uses-permission android:name="android.permission.REQUEST_INSTALL_PACKAGES" />

    <!-- The build/run daemon (:build process) promotes to a foreground service while a build or program is
         running, so the OS won't kill it if the user switches away mid-build (docs/build-process-isolation.md).
         "specialUse": a code build/run is a long-running, user-initiated task that fits no other FGS category
         (not data sync / media / location / …); the justification is declared on the <service> below for Play.
         POST_NOTIFICATIONS (API 33+) lets the ongoing "Building…" notification show; the FGS still runs without it. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- The bundled aapt2/zipalign (lib*.so) must be EXTRACTED into nativeLibraryDir at install so they can
         be exec'd (ART forbids executing binaries from anywhere else). That extraction is driven by
         packaging.jniLibs.useLegacyPackaging=true in build.gradle.kts (which sets extractNativeLibs on the
         merged manifest); declaring it here too is redundant, so AGP owns it. -->
    <!-- largeHeap: this app runs kotlinc/D8/R8 in-process (no `java` to fork on ART), so it needs far more
         heap than a normal app. largeHeap raises the per-app cap (device-dependent, often 2-4x) — the single
         biggest lever against OOM during on-device builds; the dexer also bounds its parallelism to the heap
         (see DexConcurrency). -->
    <application
            android:allowBackup="true"
            android:largeHeap="true"
            android:icon="@mipmap/ic_launcher"
            android:roundIcon="@mipmap/ic_launcher_round"
            android:label="@string/app_name"
            android:supportsRtl="true"
            android:theme="@android:style/Theme.Material.NoActionBar">
        <activity
                android:name=".MainActivity"
                android:exported="true"
                android:launchMode="singleTop"
                android:windowSoftInputMode="adjustResize"
                android:configChanges="orientation|screenSize|screenLayout|keyboardHidden|keyboard|navigation|uiMode|density|fontScale|smallestScreenSize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <!-- "Open with CodeAssist": another app hands us a single file to import into the project. -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />

                <data android:mimeType="text/*" />
                <data android:mimeType="application/json" />
                <data android:mimeType="application/xml" />
            </intent-filter>
            <!-- "Share to CodeAssist": receive a shared file from another app. -->
            <intent-filter>
                <action android:name="android.intent.action.SEND" />
                <category android:name="android.intent.category.DEFAULT" />

                <data android:mimeType="text/*" />
                <data android:mimeType="application/json" />
                <data android:mimeType="application/xml" />
            </intent-filter>
        </activity>

        <!-- Phase-2 build-process-isolation skeleton (docs/build-process-isolation.md): the build/run daemon
             runs in its own ":build" OS process so a build OOM or a user-program crash kills only it, not
             the IDE. A plain bound service for now; the foreground service + notification is Phase 5. -->
        <service
                android:name=".daemon.BuildDaemonService"
                android:process=":build"
                android:exported="false"
                android:foregroundServiceType="specialUse">
            <!-- Play requires a justification for specialUse FGS. Declare the use case here; you also enter
                 it in the Play Console at submission (Google reviews specialUse case-by-case). -->
            <property
                    android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                    android:value="Compiling and running the user's on-device software project — a long-running, user-initiated build that must continue if the user navigates away from the IDE." />
        </service>

        <!-- Real-view layout-preview renderer in its own ":preview" OS process (layout-preview Step 3): it
             inflates + draws arbitrary library/user View code off the IDE's heap, so a render crash/OOM kills
             only this process (the client falls back to in-process rendering). A plain bound service. -->
        <service
                android:name=".preview.PreviewRenderService"
                android:process=":preview"
                android:exported="false" />

        <!-- Exposes a single project file to other apps as a content:// URI for Share / "Open with",
             without FileUriExposedException. Folder-level browsing is handled by the DocumentsProvider below. -->
        <provider
                android:name="androidx.core.content.FileProvider"
                android:authorities="${applicationId}.fileprovider"
                android:exported="false"
                android:grantUriPermissions="true">
            <meta-data
                    android:name="android.support.FILE_PROVIDER_PATHS"
                    android:resource="@xml/file_paths" />
        </provider>

        <!-- Surfaces the whole app directory as a browsable, read/write root in the system Files app and
             any SAF file manager — so users can drop in icons/layouts/assets and edit project files from a
             file manager without the All-Files-Access permission (issues #1010 / #1016). The platform requires
             this provider be exported and protected by the system-only MANAGE_DOCUMENTS permission. -->
        <provider
                android:name=".ProjectsDocumentsProvider"
                android:authorities="${applicationId}.documents"
                android:exported="true"
                android:grantUriPermissions="true"
                android:permission="android.permission.MANAGE_DOCUMENTS">
            <intent-filter>
                <action android:name="android.content.action.DOCUMENTS_PROVIDER" />
            </intent-filter>
        </provider>
    </application>

</manifest>